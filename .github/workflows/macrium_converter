name: Build Macrium Converter

on: [push, workflow_dispatch] # workflow_dispatch lets you run it manually

jobs:
  build:
    runs-on: windows-latest # Must be Windows to compile the Windows executable

    steps:
    - name: Checkout Code
      uses: actions/checkout@v4

    - name: Configure CMake
      run: cmake -B build -DCMAKE_BUILD_TYPE=Release

    - name: Build Code
      run: cmake --build build --config Release

    # CRITICAL STEP: This saves the file so you can download it from the browser
    - name: Upload Compiled Executable
      uses: actions/upload-artifact@v4
      with:
        name: img_to_vhdx-executable
        path: build/src/Release/img_to_vhdx.exe
